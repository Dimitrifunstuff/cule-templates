{
  "schemaVersion": 1,
  "nativeChrome": true,
  "name": "Game Radar",
  "brand": "Cule",
  "advanced": {
    "enabled": false,
    "unsafeCSS": false
  },
  "sidebar": {
    "enabled": false,
    "width": 320,
    "title": "Game Radar"
  },
  "layout": {
    "splitView": false,
    "title": "Game Radar",
    "description": "A gaming-focused browser that auto-loads your wiki tabs based on the game you're playing."
  },
  "browser": {
    "homeUrl": "https://store.steampowered.com/",
    "addressPlaceholder": "Search the web · paste URL · jump to a wiki",
    "chromeStyles": ".tab-strip{background:linear-gradient(180deg,#0e1320 0%,#0a0e1a 100%);border-bottom:1px solid rgba(0,245,255,0.18);padding-top:4px} .tab-strip__tab{background:rgba(255,255,255,0.02);border:1px solid transparent;border-radius:8px 8px 0 0;color:#6c7689;transition:color 140ms ease,background 140ms ease,border-color 140ms ease;margin-right:2px;letter-spacing:0.2px} .tab-strip__tab:hover{background:rgba(0,245,255,0.05);color:#b3e7ff} .tab-strip__tab--active{background:linear-gradient(180deg,rgba(0,245,255,0.10) 0%,rgba(0,245,255,0.02) 100%);border:1px solid rgba(0,245,255,0.35);border-bottom:1px solid transparent;color:#e0f7ff;box-shadow:0 -2px 0 0 #00f5ff inset,0 0 18px -6px rgba(0,245,255,0.4)} .tab-strip__title{font-weight:500} .tab-strip__add{color:#6c7689;border-radius:6px;transition:color 140ms ease,background 140ms ease} .tab-strip__add:hover{color:#00f5ff;background:rgba(0,245,255,0.08)} .browser-chrome{background:#0a0e1a;border-bottom:1px solid rgba(0,245,255,0.10)} .address-bar{background:#11172a;border:1px solid rgba(0,245,255,0.15);border-radius:8px;transition:border-color 140ms ease,box-shadow 140ms ease} .address-bar:focus-within{border-color:rgba(0,245,255,0.50);box-shadow:0 0 0 3px rgba(0,245,255,0.08)} #address-input{color:#e0f7ff;letter-spacing:0.2px} #address-input::placeholder{color:#4f5a73} .nav-button{color:#a8b1c4;background:transparent;border-radius:6px;transition:color 140ms ease,background 140ms ease} .nav-button:hover{background:rgba(0,245,255,0.08);color:#00f5ff} .browser-status{color:#6c7689;font-family:'JetBrains Mono','Consolas',monospace;font-size:11px;letter-spacing:0.4px} .browser-surface{background:#070a14} .workspace{background:#070a14} .mode-drawer{background:#0a0e1a;border-right:1px solid rgba(0,245,255,0.10)} #address-input{border:none;background:transparent;border-radius:0} .tab-strip__tab--active::before,.tab-strip__tab--active::after{display:none}",
    "previewViews": [],
    "chrome": {
      "uiFontFamily": "\"Inter\", \"Segoe UI\", system-ui, sans-serif",
      "uiScale": 1,
      "tabStyle": "default",
      "theme": {
        "surface": "#0a0e1a",
        "surfaceAlt": "#11172a",
        "border": "#1f2940",
        "text": "#e0f7ff",
        "mutedText": "#6c7689",
        "accent": "#00f5ff",
        "addressBar": "#11172a",
        "addressBarText": "#e0f7ff",
        "buttonSurface": "rgba(255, 255, 255, 0.05)",
        "buttonText": "#a8b1c4"
      }
    },
    "pageStyles": [],
    "behaviors": {
      "celebrateOnNewTab": false,
      "companion": {
        "enabled": false,
        "emoji": "🐾",
        "label": "Companion",
        "curiosity": "off"
      }
    },
    "internalPages": {
      "welcome": "data:text/html;base64,"
    },
    "searchEngine": null,
    "showNavigation": true
  },
  "modules": [
    {
      "id": "mode-overview",
      "enabled": true,
      "placement": "sidebar",
      "config": {}
    },
    {
      "id": "welcome",
      "enabled": true,
      "placement": "main",
      "config": {}
    }
  ]
}
